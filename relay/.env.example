# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# Bearer token — OPTIONAL. Leave EMPTY for a LAN-only relay (no auth needed).
# Only set it if you expose the relay beyond the LAN (e.g. over a tunnel):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_TOKEN=

# Single-printer shortcut (find SERIAL + ACCESS_CODE on the printer screen:
# Settings > Network / LAN-only mode). IP is the printer's LAN address.
PRINTER_SERIAL=
PRINTER_IP=
PRINTER_ACCESS_CODE=
PRINTER_NAME=My X1C

# OR configure several printers as a JSON list (overrides/adds to the shortcut):
# PRINTERS=[{"serial":"01P00...","ip":"192.168.1.50","access_code":"12345678","name":"X1C"}]

# Server bind (defaults are fine inside Docker)
HOST=0.0.0.0
PORT=8979
